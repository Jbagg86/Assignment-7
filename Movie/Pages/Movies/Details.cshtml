@page "{id:int?}"
@model RazorPagesMovie.Pages.Movies.DetailsModel

@{
    ViewData["Title"] = "Movie Details - " + Model.Movie.Title;
}

<div class="container mt-4">
    <div class="card shadow-sm p-4">
        <div class="row">
            <div class="col-md-4 text-center mb-3 mb-md-0">
                <img src="@Model.Movie.ImageUri"
                     alt="@Model.Movie.Title"
                     class="img-fluid rounded"
                     style="max-height: 450px;" />
            </div>

            <div class="col-md-8">
                <h2 class="fw-bold mb-3">@Model.Movie.Title</h2>

                <p><strong>Rank:</strong> @Model.Movie.Rank</p>
                <p><strong>Price:</strong> @Model.Movie.Price.ToString("C")</p>
                <p><strong>Release Date:</strong> @Model.Movie.ReleaseDate.ToShortDateString()</p>
                <p><strong>Genre:</strong> @Model.Movie.Genre</p>

                <div class="mt-4">
                    <a asp-page="./Index" class="btn btn-secondary">Back</a>
                    <button class="btn btn-primary">Add to Cart</button>
                </div>
            </div>
        </div>
    </div>
</div>